@using BlazorMVVMExample_1.Shared
@using BlazorMVVMExample_1.Client.ViewModels

@* This identifies the route, relative URL of this page. *@

@page "/fetchdata" 

@* This identifies the interface of the view model and the name  *@
@* of an instance that will be created by the framework from the *@
@* directives setup on the client's Program.cs file.             *@

@inject IWeatherForecastsViewModel ViewModel

<PageTitle>Weather forecast</PageTitle>

<h1>Weather forecast</h1>

<p>This component demonstrates rendering data from a view model.</p>

@if (ViewModel.WeatherForecasts == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Temp. (C)</th>
                <th>Temp. (F)</th>
                <th>Summary</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var forecast in ViewModel.WeatherForecasts)
            {
                <tr>
                    <td>@forecast.Date.ToShortDateString()</td>
                    <td>@forecast.TemperatureC</td>
                    <td>@forecast.TemperatureF</td>
                    <td>@forecast.Summary</td>
                </tr>
            }
        </tbody>
    </table>
}